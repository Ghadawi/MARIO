@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@700;900&display=swap');

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    overflow: hidden;
    font-family: 'Cairo', sans-serif;
}

#game-container {
    position: relative;
    width: 100vw;
    height: 100vh;
    border: none;
    border-radius: 0;
    overflow: hidden;
    box-shadow: none;
}

canvas {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
}

/* Screens */
.screen {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(180deg, #3a78e8 0%, #5c94fc 15%, #87CEEB 40%, #a8e6a8 65%, #4a8f3f 80%, #3a7a2f 100%);
    z-index: 10;
    overflow: hidden;
}

/* Clouds */
.cloud {
    position: absolute;
    background: #fff;
    border-radius: 50%;
    z-index: 3;
    opacity: 0.9;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));
}
.cloud::before, .cloud::after {
    content: '';
    position: absolute;
    background: #fff;
    border-radius: 50%;
}
.cloud-1 {
    width: 120px; height: 50px;
    top: 8%; left: -5%;
    animation: cloudMove 25s linear infinite;
}
.cloud-1::before { width: 60px; height: 60px; top: -30px; left: 20px; }
.cloud-1::after { width: 80px; height: 45px; top: -20px; left: 50px; }

.cloud-2 {
    width: 100px; height: 40px;
    top: 15%; left: -10%;
    animation: cloudMove 35s linear infinite;
    animation-delay: -10s;
}
.cloud-2::before { width: 50px; height: 50px; top: -25px; left: 15px; }
.cloud-2::after { width: 65px; height: 38px; top: -18px; left: 40px; }

.cloud-3 {
    width: 140px; height: 55px;
    top: 5%; left: -8%;
    animation: cloudMove 30s linear infinite;
    animation-delay: -20s;
}
.cloud-3::before { width: 70px; height: 65px; top: -35px; left: 25px; }
.cloud-3::after { width: 90px; height: 50px; top: -22px; left: 55px; }

.cloud-4 {
    width: 90px; height: 35px;
    top: 20%; left: -6%;
    animation: cloudMove 40s linear infinite;
    animation-delay: -5s;
    opacity: 0.7;
}
.cloud-4::before { width: 45px; height: 45px; top: -22px; left: 12px; }
.cloud-4::after { width: 55px; height: 32px; top: -15px; left: 35px; }

.cloud-5 {
    width: 110px; height: 42px;
    top: 12%; left: -7%;
    animation: cloudMove 28s linear infinite;
    animation-delay: -15s;
    opacity: 0.8;
}
.cloud-5::before { width: 55px; height: 55px; top: -28px; left: 18px; }
.cloud-5::after { width: 70px; height: 40px; top: -18px; left: 45px; }

@keyframes cloudMove {
    0% { transform: translateX(-200px); }
    100% { transform: translateX(calc(100vw + 200px)); }
}

/* Mario Hero */
#mario-hero {
    position: absolute;
    right: 8%;
    bottom: 90px;
    z-index: 4;
    width: 90px;
    height: 130px;
    animation: marioHeroFloat 3s ease-in-out infinite;
    filter: drop-shadow(3px 6px 8px rgba(0,0,0,0.3));
}

@keyframes marioHeroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
}

/* Ground strip */
.ground-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 80px;
    background: linear-gradient(180deg, #4a8f3f 0%, #8B4513 15%, #6d3410 100%);
    z-index: 1;
}
.ground-strip::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: #5aaf5a;
}

/* Grass blades */
.grass-layer {
    position: absolute;
    bottom: 70px;
    left: 0;
    width: 100%;
    height: 60px;
    z-index: 2;
    pointer-events: none;
}

.grass-blade {
    position: absolute;
    bottom: 0;
    width: 8px;
    height: 30px;
    border-radius: 50% 50% 0 0;
    transform-origin: bottom center;
    animation: grassSway 2s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.15s);
}

.grass-blade:nth-child(odd) {
    background: linear-gradient(to top, #3a8f3a, #5abf5a);
    height: 35px;
    width: 6px;
}
.grass-blade:nth-child(even) {
    background: linear-gradient(to top, #2d7a2d, #4aaf4a);
    height: 25px;
    width: 5px;
}

.grass-blade:nth-child(1)  { left: 2%; }
.grass-blade:nth-child(2)  { left: 7%; }
.grass-blade:nth-child(3)  { left: 12%; }
.grass-blade:nth-child(4)  { left: 17%; }
.grass-blade:nth-child(5)  { left: 22%; }
.grass-blade:nth-child(6)  { left: 27%; }
.grass-blade:nth-child(7)  { left: 32%; }
.grass-blade:nth-child(8)  { left: 37%; }
.grass-blade:nth-child(9)  { left: 42%; }
.grass-blade:nth-child(10) { left: 47%; }
.grass-blade:nth-child(11) { left: 52%; }
.grass-blade:nth-child(12) { left: 57%; }
.grass-blade:nth-child(13) { left: 62%; }
.grass-blade:nth-child(14) { left: 67%; }
.grass-blade:nth-child(15) { left: 72%; }
.grass-blade:nth-child(16) { left: 77%; }
.grass-blade:nth-child(17) { left: 82%; }
.grass-blade:nth-child(18) { left: 87%; }
.grass-blade:nth-child(19) { left: 92%; }
.grass-blade:nth-child(20) { left: 97%; }

/* Extra grass tufts via pseudo-elements */
.grass-blade::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 8px;
    width: 5px;
    height: 20px;
    background: linear-gradient(to top, #3a9a3a, #6ad06a);
    border-radius: 50% 50% 0 0;
    transform: rotate(15deg);
    transform-origin: bottom center;
}

.grass-blade::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -6px;
    width: 4px;
    height: 22px;
    background: linear-gradient(to top, #2d8a2d, #50b050);
    border-radius: 50% 50% 0 0;
    transform: rotate(-12deg);
    transform-origin: bottom center;
}

@keyframes grassSway {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
}

.title-wrapper {
    text-align: center;
    margin-bottom: 40px;
    animation: bounceIn 1s ease;
}

.game-title {
    font-size: 64px;
    font-weight: 900;
    background: linear-gradient(90deg, 
        #ff0000, #ff8800, #ffff00, #00cc00, #0088ff, #8800ff, #ff00ff, #ff0000);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: titleFloat 3s ease-in-out infinite, rainbowShift 3s linear infinite;
    letter-spacing: 4px;
    filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.4)) drop-shadow(6px 6px 0 rgba(0,0,0,0.2));
}

@keyframes rainbowShift {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
}

.subtitle {
    font-size: 24px;
    background: linear-gradient(90deg, #ffd700, #ff8c00, #ffd700);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: rainbowShift 4s linear infinite;
    margin-top: 8px;
    filter: drop-shadow(2px 2px 0 rgba(0,0,0,0.3));
}

@keyframes titleFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

@keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
}

.coin-animation {
    position: absolute;
    font-size: 40px;
    animation: coinSpin 2s linear infinite;
    bottom: 30%;
    right: 15%;
}

@keyframes coinSpin {
    0% { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
}

/* Menu Buttons */
.menu-btn {
    background: linear-gradient(180deg, #e52521, #b91d1a);
    color: #fff;
    border: 4px solid #8b0000;
    border-radius: 12px;
    padding: 14px 48px;
    font-size: 22px;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    margin: 8px;
    transition: all 0.2s;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.3);
    box-shadow: 0 6px 0 #8b0000, 0 8px 10px rgba(0,0,0,0.3);
}

.menu-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 9px 0 #8b0000, 0 12px 15px rgba(0,0,0,0.3);
    background: linear-gradient(180deg, #ff3b37, #e52521);
}

.menu-btn:active {
    transform: translateY(3px);
    box-shadow: 0 3px 0 #8b0000, 0 4px 5px rgba(0,0,0,0.3);
}

.play-btn {
    background: linear-gradient(180deg, #00cc44, #009933);
    border-color: #006622;
    box-shadow: 0 6px 0 #006622, 0 8px 10px rgba(0,0,0,0.3);
    font-size: 26px;
    padding: 16px 60px;
}
.play-btn:hover {
    background: linear-gradient(180deg, #00ee55, #00cc44);
    box-shadow: 0 9px 0 #006622, 0 12px 15px rgba(0,0,0,0.3);
}
.play-btn:active {
    box-shadow: 0 3px 0 #006622, 0 4px 5px rgba(0,0,0,0.3);
}

.ctrl-btn {
    background: linear-gradient(180deg, #3388ff, #2266cc);
    border-color: #1144aa;
    box-shadow: 0 6px 0 #1144aa, 0 8px 10px rgba(0,0,0,0.3);
}
.ctrl-btn:hover {
    background: linear-gradient(180deg, #55aaff, #3388ff);
    box-shadow: 0 9px 0 #1144aa, 0 12px 15px rgba(0,0,0,0.3);
}
.ctrl-btn:active {
    box-shadow: 0 3px 0 #1144aa, 0 4px 5px rgba(0,0,0,0.3);
}

/* Controls Screen */
.controls-grid {
    background: rgba(0,0,0,0.3);
    border-radius: 16px;
    padding: 24px 40px;
    margin: 20px 0;
}

.control-item {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 12px 0;
    color: #fff;
    font-size: 18px;
}

.key {
    background: #333;
    color: #ffd700;
    padding: 6px 16px;
    border-radius: 8px;
    border: 2px solid #555;
    font-family: monospace;
    font-size: 16px;
    min-width: 150px;
    text-align: center;
}

#controls-screen h2 {
    font-size: 36px;
    color: #fff;
    text-shadow: 3px 3px 0 #333;
}

/* HUD */
#hud {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-around;
    padding: 10px 20px;
    background: rgba(0,0,0,0.5);
    z-index: 5;
    border-bottom: 3px solid rgba(255,215,0,0.3);
}

.hud-item {
    color: #fff;
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    text-shadow: 2px 2px 0 #000, 0 0 10px rgba(255,215,0,0.3);
}

/* Game Over */
.gameover-title {
    font-size: 56px;
    color: #e52521;
    text-shadow: 4px 4px 0 #000;
    animation: shake 0.5s ease;
}

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
}

.win-title {
    font-size: 56px;
    color: #ffd700;
    text-shadow: 4px 4px 0 #8b6914;
    animation: bounceIn 0.8s ease;
}

.final-score {
    font-size: 28px;
    color: #fff;
    margin: 16px 0;
    text-shadow: 2px 2px 0 #000;
}

/* Mobile Controls */
#mobile-controls {
    position: absolute;
    bottom: 10px;
    left: 0; right: 0;
    z-index: 15;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    pointer-events: none;
}

.mobile-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: 3px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 24px;
    cursor: pointer;
    pointer-events: all;
    -webkit-user-select: none;
    user-select: none;
    touch-action: none;
}

.mobile-btn:active {
    background: rgba(255,255,255,0.6);
}

.jump-btn {
    position: absolute;
    right: 20px;
    bottom: 80px;
    width: 80px;
    height: 80px;
    font-size: 30px;
}

/* Mario Face */
#mario-face {
    position: absolute;
    bottom: 20px;
    left: 20px;
    z-index: 20;
    width: 80px;
    height: 80px;
    pointer-events: none;
    animation: marioFloat 2s ease-in-out infinite;
}

@keyframes marioFloat {
    0%, 100% { transform: translateY(0) rotate(-3deg); }
    50% { transform: translateY(-8px) rotate(3deg); }
}

#mario-face.laugh {
    animation: marioLaugh 0.3s ease infinite;
}

@keyframes marioLaugh {
    0%, 100% { transform: scale(1) rotate(-2deg); }
    50% { transform: scale(1.1) rotate(2deg); }
}

/* Responsive */
@media (max-width: 980px) {
    #game-container {
        width: 100vw;
        height: 100vh;
    }
}

@media (max-width: 600px) {
    .game-title { font-size: 36px; }
    .subtitle { font-size: 16px; }
    .menu-btn { font-size: 16px; padding: 10px 30px; }
}
